{
    "name": "signdocs-brasil/signdocs-brasil-php",
    "description": "Official PHP SDK for the SignDocsBrasil API — digital document signing with ICP-Brasil support",
    "type": "library",
    "version": "1.1.0",
    "license": "MIT",
    "keywords": [
        "signdocs",
        "signdocs-brasil",
        "digital-signature",
        "icp-brasil",
        "electronic-signature",
        "document-signing",
        "pkcs7"
    ],
    "homepage": "https://signdocs.com.br",
    "support": {
        "issues": "https://github.com/signdocsbrasil/signdocs-brasil-php/issues",
        "source": "https://github.com/signdocsbrasil/signdocs-brasil-php"
    },
    "authors": [
        {
            "name": "SignDocsBrasil",
            "email": "dev@signdocs.com.br"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "firebase/php-jwt": "^6.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "SignDocsBrasil\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SignDocsBrasil\\Api\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "audit": {
            "abandoned": "report",
            "block-insecure": false
        }
    }
}
